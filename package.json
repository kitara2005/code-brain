{
  "name": "code-brain",
  "version": "0.2.0",
  "description": "Turn any codebase into searchable knowledge for Claude Code. LLM Wiki + AST Index + MCP Server.",
  "type": "module",
  "bin": {
    "code-brain": "./bin/code-brain.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node scripts/postinstall.cjs || true",
    "build-index": "node dist/indexer/index-builder.js",
    "serve": "node dist/mcp/server.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitara2005/code-brain.git"
  },
  "homepage": "https://github.com/kitara2005/code-brain#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist/",
    "bin/",
    "skill/",
    "scripts/",
    "templates/"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^5.0.0",
    "sql.js": "^1.12.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-php": "^0.23.12",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-rust": "^0.23.2",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.2",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "tree-sitter",
      "tree-sitter-go",
      "tree-sitter-java",
      "tree-sitter-javascript",
      "tree-sitter-php",
      "tree-sitter-python",
      "tree-sitter-rust",
      "tree-sitter-typescript"
    ]
  },
  "keywords": [
    "claude-code",
    "mcp",
    "codebase",
    "wiki",
    "ast",
    "index",
    "tree-sitter"
  ],
  "license": "MIT"
}
